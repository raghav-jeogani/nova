OPENAI_API_KEY=sk-...
# PostgreSQL (required). Example: postgresql://user:pass@localhost:5432/nova_daw
DATABASE_URL=postgresql://user:password@localhost:5432/nova_daw
# Optional pool size (default 10)
# PG_POOL_MAX=10

# Optional overrides
OPENAI_VISION_MODEL=gpt-4o
OPENAI_TEXT_MODEL=gpt-4o-mini
PORT=3001
RULES_DIR=./rules

# Gmail SMTP (optional — required for POST /api/email/send-draft from the CG UI)
# Use a Google Account App Password (not your normal Gmail password): https://support.google.com/accounts/answer/185833
# Either pair works; pick one naming scheme:
# GMAIL_USER=you@gmail.com
# GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
